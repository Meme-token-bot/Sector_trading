OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

TIGER_ID=
TIGER_ACCOUNT=
TIGER_PRIVATE_KEY_PATH=./tiger_private_key.pem
TIGER_SANDBOX=false

# Gmail (REST API via OAuth 2.0). See SETUP.md → "Connecting Gmail".
# Run `PYTHONPATH=. python scripts/gmail_oauth_setup.py` once to mint the token.
GMAIL_ADDRESS=you@gmail.com
# The +alias variant you subscribe newsletters to. Leave blank to fetch all unread mail.
GMAIL_FILTER_ADDRESS=you+macro@gmail.com
GMAIL_CREDENTIALS_FILE=credentials/gmail_credentials.json
GMAIL_TOKEN_FILE=credentials/gmail_token.json

# FRED API key — required for all macro indicators (yield curve, HY OAS,
# real rates, breakeven inflation, etc.). Without it every macro fetch
# silently falls back to NaN and the macro overlay is dark.
# Free key at: https://fredaccount.stlouisfed.org/login/secure/
FRED_API_KEY=