OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

TIGER_ID=
TIGER_ACCOUNT=
TIGER_PRIVATE_KEY_PATH=./tiger_private_key.pem
TIGER_SANDBOX=false

# Gmail (IMAP via app password). Generate at myaccount.google.com/apppasswords
# (2FA must be enabled on your Google account first).
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=
# The +alias variant you subscribe newsletters to. Leave blank to fetch all unread mail.
GMAIL_FILTER_ADDRESS=you+macro@gmail.com
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
